{
  "name": "organizer",
  "version": "1.0.0",
  "description": "Automatic file organizer for macOS and Windows",
  "main": "./out/main/index.js",
  "author": "Organizer",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "dist": "electron-vite build && electron-builder --config electron-builder.yml",
    "dist:mac": "electron-vite build && electron-builder --mac --config electron-builder.yml",
    "dist:win": "electron-vite build && electron-builder --win --config electron-builder.yml"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "chokidar": "^4.0.3",
    "electron-store": "^10.0.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
